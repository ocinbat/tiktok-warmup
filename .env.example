# ─────────────────────────────────────────────────────────────
# AI PROVIDER SELECTION
# Pick which backend the bot uses. Leave unset to keep the original
# Google Gemini behavior. One of: google | minimax | anthropic | openai-compatible
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=google

# Max tool-use steps per screen interaction before the agent is stopped.
# Slower/exploratory models (e.g. MiniMax M3) may need more than the default 40.
# AGENT_MAX_STEPS=40

# Hard cap on tokens generated per agent step. Unset = no cap (fine for cloud
# models like Gemini). Set it (e.g. 8192) to rein in a verbose LOCAL reasoning
# model that burns 15-20k reasoning tokens per call. Keep it generous (>= 2048)
# or the model gets cut off before it emits its tool call.
# EXCEPTION: on MiniMax "unset" is not no-cap — the Anthropic-style API requires
# max_tokens, so the bot auto-defaults BOTH caps below to 8192 there.
# AGENT_MAX_OUTPUT_TOKENS=8192
# Same cap for the vision sub-calls (screen analysis / coordinate detection).
# VISION_MAX_OUTPUT_TOKENS=8192

# Order of the 4 numbers a vision model returns for a bounding box.
#   yxyx (default) -> [y1, x1, y2, x2]  — Gemini, MiniMax-M3 (calibrated)
#   xyxy           -> [x1, y1, x2, y2]  — Qwen-VL & most OpenAI-style vision models
# A wrong order swaps X and Y, so taps land in the wrong place.
# Verify any new provider with:  pnpm test-provider  (no device needed — it
# smoke-tests text + vision and calibrates the box order on a synthetic image).
# VISION_BOX_ORDER=xyxy

# Two-stage coordinate detection: coarse find -> crop & zoom -> precise find.
# Defaults ON for MiniMax (fixes M3's consistent ~8-10% downward y-bias; tap
# accuracy 8% -> 92% on the bench, see src/scripts/bench-vision.ts), OFF for
# other providers. Costs one extra vision call per detection.
# VISION_ZOOM_REFINE=true

# Per-character delay (ms) when typing text over adb. Old/slow phones drop
# characters if typed too fast; raise this if comments come out truncated.
# ADB_INPUT_CHAR_DELAY_MS=120

# Comment-flow "settle" wait (seconds) — used where the UI genuinely lags:
# panel/keyboard appearing, text registering, post landing. Navigation taps and
# back-presses automatically wait half this. Raise it for slow/laggy phones so a
# comment never truncates; lower it to speed the flow up.
# COMMENT_STEP_WAIT_S=4

# Language the bot writes comments in (e.g. English, Turkish, Spanish, German).
# Turkish characters are transliterated to ASCII (çok güzel -> cok guzel) so they
# type over adb without a custom keyboard.
# COMMENT_LANGUAGE=English

# Only comment when the video's own language matches COMMENT_LANGUAGE (so the bot
# doesn't write e.g. Turkish comments on unrelated foreign videos — it skips them
# and moves on). Language-neutral videos (pure music/visuals) still get comments.
# On by default; set to false to comment regardless of the video's language.
# COMMENT_REQUIRE_LANGUAGE_MATCH=true

# Per-video probability (0..1) of liking / commenting. Defaults are conservative
# and human-like (like ~1/45 videos, comment ~1/150). While TESTING that the
# learned like/comment coordinates work, crank these up — e.g. set both to 1 to
# like and comment on every video.
# LIKE_CHANCE=0.0222
# COMMENT_CHANCE=0.00665

# ── Niche-follow: grow the account by following creators in a niche ──
# A video is follow-scanned either on its own FOLLOW_CHANCE roll OR (when
# FOLLOW_ON_LIKE=true) whenever the bot LIKES it. If the creator matches BOTH the
# niche AND language and isn't already followed, the bot taps Follow. Works on
# TikTok (avatar + red "+" badge) and Instagram (the "Follow"/"Takip Et" button).
# Defaults target Turkish skincare channels.
# FOLLOW_ENABLED=true
# FOLLOW_NICHE=skincare / cilt bakımı (skincare routines, derma/beauty, cleansers, serums, sunscreen)
# FOLLOW_LANGUAGE=Turkish
# Per-video probability of running the follow scan (~1 in 25 at 0.04).
# FOLLOW_CHANCE=0.04
# Also follow-scan every video that gets liked (engaged videos always checked).
# FOLLOW_ON_LIKE=true
# Safety cap: max follows per session. Following many accounts fast is a ban signal.
# FOLLOW_DAILY_LIMIT=30

# ── google (default) ─────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=AIz..............
# Optional model override (default: gemini-2.5-pro)
# GOOGLE_MODEL=gemini-2.5-pro

# ── Hybrid: vision on a different provider than orchestration ─
# Run precise coordinate/screen-analysis calls on a stronger grounding model
# (Gemini) while the agent loop stays on AI_PROVIDER. Defaults to AI_PROVIDER.
# VISION_PROVIDER=google
# VISION_MODEL=gemini-2.5-pro   # optional override for the vision model

# ── minimax (Coding/Token Plan or pay-as-you-go) ─────────────
# IMPORTANT: this bot is vision-driven (it sends device screenshots),
# so you MUST use a multimodal model. MiniMax-M3 is the only current
# MiniMax model that accepts image input — M2 / M2.1 will NOT work.
# Coding/Token Plan subscription keys start with "sk-cp-" and DO work here.
# M3 answers bounding boxes y-first, so leave VISION_BOX_ORDER unset.
# MINIMAX_API_KEY=your_minimax_subscription_or_api_key
# MINIMAX_MODEL=MiniMax-M3
# For the full 1M context window use the id MiniMax's own Claude Code
# config uses (plain MiniMax-M3 advertises 200K on this endpoint):
# MINIMAX_MODEL=MiniMax-M3[1m]
# How to talk to MiniMax: "anthropic" (default; the documented path for the
# Coding/Token Plan subscription key) or "openai" (pay-as-you-go platform key).
# MINIMAX_API_STYLE=anthropic
# Override the host only if needed.
#   International (default): https://api.minimax.io/anthropic/v1  (anthropic style)
#                            https://api.minimax.io/v1           (openai style)
#   China mainland:          https://api.minimaxi.com/anthropic/v1  /  https://api.minimaxi.com/v1
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic/v1

# ── anthropic (real Claude) ──────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── openai-compatible (any OpenAI-style endpoint) ────────────
# OPENAI_COMPATIBLE_API_KEY=...
# OPENAI_COMPATIBLE_BASE_URL=https://api.example.com/v1
# OPENAI_COMPATIBLE_MODEL=some-vision-model
# OPENAI_COMPATIBLE_NAME=openai-compatible

# ── LM Studio (local, OpenAI-compatible) — e.g. qwen/qwen3-vl-8b ──
# Fully local setup: orchestration AND vision on one local vision model.
# In LM Studio: Developer tab -> Start Server (port 1234), then Load the model.
# AI_PROVIDER=openai-compatible
# VISION_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPATIBLE_MODEL=qwen/qwen3-vl-8b
# OPENAI_COMPATIBLE_API_KEY=lm-studio   # any non-empty value; LM Studio ignores it
# OPENAI_COMPATIBLE_NAME=lmstudio
# VISION_BOX_ORDER=xyxy                  # REQUIRED for Qwen-VL (x-first boxes)
